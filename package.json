{
  "name": "@asp-protocol/asp",
  "version": "0.0.1",
  "description": "Turn any website into a queryable knowledge base for AI agents",
  "license": "MIT",
  "author": "Ian Kiku <https://github.com/iankiku>",
  "homepage": "https://github.com/iankiku/agent-search-protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/iankiku/agent-search-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/iankiku/agent-search-protocol/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "search",
    "protocol",
    "mcp",
    "knowledge-base",
    "rag",
    "crawl"
  ],
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "asp": "./bin/asp.js",
    "agent-search-protocol": "./bin/asp.js"
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "scripts"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "index": "bun src/cli.ts index",
    "serve": "bun src/cli.ts serve",
    "build": "node scripts/build.mjs",
    "build:docker": "docker build -t agent-search-protocol:latest -t agent-search-protocol:$(cat package.json | jq -r .version) .",
    "publish": "npm publish --access public",
    "release": "npm version patch && npm publish --access public && git push origin main --tags",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf .asp node_modules dist asp-bin",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@indiekitai/lipgloss": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tobilu/qmd": "^2.0.1",
    "cheerio": "^1.0.0-rc.12",
    "crawlee": "^3.16.0",
    "hono": "^4.12.7",
    "ora": "^9.3.0",
    "turndown": "^7.2.2",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@mendable/firecrawl-js": "*"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "ai": "^6.0.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3",
    "zod": "^3.23.0"
  }
}
